# ========== API 配置 ==========
# 阿里云百炼 API Key (https://dashscope.console.aliyun.com/)
DASHSCOPE_API_KEY = "sk-your-dashscope-api-key-here"

# PaddleOCR API Token (可选，用于 PDF/DOCX 解析)
PADDLEOCR_TOKEN = "your-paddleocr-token-here"

# ========== 模型配置 ==========
# Embedding 模型 (阿里云百炼)
EMBEDDING_MODEL = "text-embedding-v3"

# LLM 模型 (阿里云百炼)
LLM_MODEL = "qwen-flash"

# ========== RAG 配置 ==========
# 分块大小
CHUNK_SIZE = 512
# 分块重叠
CHUNK_OVERLAP = 50
# 检索数量
TOP_K = 5
# 重排序候选数量
RERANK_CANDIDATES = 50
